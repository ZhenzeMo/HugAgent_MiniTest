# Copy this file to .env and fill in your API keys
# cp .env.sample .env

# Alibaba DashScope (Qwen / DeepSeek models via DashScope)
# Get key at: https://dashscope.aliyuncs.com/
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Novita AI (Llama models)
# Get key at: https://novita.ai/
LLAMA_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (GPT-4o, o1, o3, GPT-5 etc.)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Anthropic Claude
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: LLM behavior tuning (defaults shown)
# LLM_RANDOM_SEED=42
# LLM_TEMPERATURE=0.1
